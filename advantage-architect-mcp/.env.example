# Copy to .env and fill in your own values. Never commit the real .env.
DB_SERVER=localhost            # SQL Server host\instance backing Advantage
DESIGN_DB=REPOSITORY           # the Architect design database (default catalog)
RUNTIME_DB=AAD                 # the runtime database (reached via 3-part names)
DB_USER=your_sql_login
DB_PASS=your_sql_password
