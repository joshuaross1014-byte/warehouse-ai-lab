# Copy to .env and fill in. .env is git-ignored and must NEVER be committed.
# The connection variables (WMS_*, ERP_*, RPA_*) are read from ../connectors/.env
# — set them there. This file is only the monitor/alerting config.

# --- Slack alerting -------------------------------------------------------
# Preferred: a bot token (xoxb-...) with chat:write + a channel/DM id. Required
# to target a specific channel/DM id.
MONITOR_SLACK_TOKEN=
MONITOR_SLACK_CHANNEL=

# Alternative: an Incoming Webhook URL (posts only to the channel it was made
# for). Used only if MONITOR_SLACK_TOKEN is unset.
MONITOR_SLACK_WEBHOOK=

# Until a token (or webhook) is set, alerts are logged + printed (dry-run), NOT sent.

# --- Optional thresholds (defaults shown) --------------------------------
MONITOR_PRICEGAP_THRESHOLD=1000
MONITOR_BOT_FAILRATE=0.10
MONITOR_BOT_MINRUNS=5
MONITOR_BOT_MINFAILS=2
