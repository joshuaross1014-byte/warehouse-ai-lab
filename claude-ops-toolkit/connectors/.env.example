# Copy to .env and fill in. .env is git-ignored and must NEVER be committed.

# --- WMS (SQL Server) ---
WMS_DB_HOST=your-sqlserver-host
WMS_DB_NAME=your-wms-db
WMS_DB_USER=your-sql-login
WMS_DB_PASS=your-password
# WMS_DB_DRIVER=ODBC Driver 18 for SQL Server

# --- ERP (SAP B1 on HANA) ---
ERP_HANA_HOST=your-hana-host
ERP_HANA_PORT=30015
ERP_HANA_USER=your-readonly-login
ERP_HANA_PASS=your-password
ERP_HANA_SCHEMA=YOUR_COMPANY_SCHEMA

# --- RPA control room (Automation Anywhere-style) ---
RPA_URL=https://your-control-room
RPA_USER=your-bot-user
RPA_APIKEY=your-api-key
# RPA_PASS=your-password   # used only if RPA_APIKEY is unset
